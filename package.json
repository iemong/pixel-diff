{
  "name": "pixel-diff",
  "version": "0.6.0",
  "description": "Pixel-level PNG/URL diff CLI powered by pixelmatch. URL mode uses agent-browser. Runnable via `bunx iemong/pixel-diff` — no install, no registry.",
  "type": "module",
  "module": "index.ts",
  "bin": {
    "pixel-diff": "./index.ts"
  },
  "scripts": {
    "diff": "bun run index.ts",
    "start": "bun run index.ts"
  },
  "keywords": [
    "pixelmatch",
    "diff",
    "image",
    "png",
    "visual-regression",
    "cli",
    "bun"
  ],
  "author": "iemong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iemong/pixel-diff.git"
  },
  "bugs": {
    "url": "https://github.com/iemong/pixel-diff/issues"
  },
  "homepage": "https://github.com/iemong/pixel-diff#readme",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0"
  }
}
